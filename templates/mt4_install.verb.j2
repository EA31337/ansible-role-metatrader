#!/bin/sh

w_metadata mt4_install apps \
    title="MetaTrader 4" \
    year="2021" \
    media="download"

# Override winetricks' built-in w_ahk_do to support heredoc and 64-bit AHK on Alpine.
w_ahk_do()
{
    local _ahk_ver="1.1.36.01"
    local _ahk_dir="${W_CACHE}/ahk"
    local _ahk_setup="${_ahk_dir}/AutoHotkey_${_ahk_ver}_setup.exe"
    local _script_dir="${WINEPREFIX:-${HOME}/.wine}/drive_c/windows/temp/_${W_PACKAGE}"
    local _script="${_script_dir}/${W_PACKAGE}.ahk"

    # Detect architecture. Use 64-bit on Alpine or if WINEARCH is win64.
    local _ahk_exe="AutoHotkeyU32.exe"
    if [ -f /etc/alpine-release ] || [ "$WINEARCH" = "win64" ]; then
        _ahk_exe="AutoHotkeyU64.exe"
    fi

    local _7z_exe="7z"
    if ! command -v 7z >/dev/null 2>&1; then
        if command -v 7zz >/dev/null 2>&1; then
            _7z_exe="7zz"
        elif command -v 7za >/dev/null 2>&1; then
            _7z_exe="7za"
        else
            w_die "w_ahk_do: '7z', '7zz' or '7za' is required (install 7zip or p7zip)"
        fi
    fi

    mkdir -p "${_ahk_dir}" "${_script_dir}"
    if [ ! -f "${_ahk_setup}" ]; then
        w_try curl -fL "https://github.com/AutoHotkey/AutoHotkey/releases/download/v${_ahk_ver}/AutoHotkey_${_ahk_ver}_setup.exe" \
            -o "${_ahk_setup}"
    fi

    if [ ! -f "${_ahk_dir}/${_ahk_exe}" ]; then
        w_try "${_7z_exe}" x "${_ahk_setup}" -o"${_ahk_dir}" "${_ahk_exe}" -y
    fi

    rm -f "${_script}"
    if [ $# -gt 0 ]; then
        for _line in "$@"; do
            printf "%s\n" "${_line}" >> "${_script}"
        done
    else
        # Remove leading spaces from heredoc to ensure clean AHK script.
        # We use a more careful sed to only remove the common 8-space indentation if possible,
        # but removing all leading whitespace is also fine for AHK.
        sed 's/^[[:space:]]*//' >> "${_script}"
    fi

    # Use winetricks' ${WINE} if available, otherwise fallback to wine.
    w_try ${WINE:-wine} "${_ahk_dir}/${_ahk_exe}" "${_script}"
}

load_mt4_install()
{
    w_download {{ metatrader_setup_url }}

    if w_workaround_wine_bug 7156 "${title} needs wingdings.ttf, installing opensymbol"
    then
        # Install opensymbol font directly, bypassing w_call opensymbol which uses
        # syswow64/regedit.exe - absent in wow64-only wine (e.g. Alpine linux).
        _font_dir="${WINEPREFIX:-${HOME}/.wine}/drive_c/windows/Fonts"
        mkdir -p "${_font_dir}"
        if curl -fsSL -o "${_font_dir}/opensymbol.ttf" \
            "https://raw.githubusercontent.com/apache/openoffice/5f13fa00702a0abe48858d443bc306f5c5ba26d8/main/extras/source/truetype/symbol/opens___.ttf"; then
            wine reg add "HKLM\\Software\\Microsoft\\Windows NT\\CurrentVersion\\Fonts" \
                /v "OpenSymbol (TrueType)" /t REG_SZ /d "opensymbol.ttf" /f 2>/dev/null || true
        fi
    fi

    # Hide Wine from debugger detection
    w_try wine reg add "HKLM\\Software\\Wine" /v "HideWineExports" /t REG_SZ /d "Y" /f
    w_try wine reg add "HKCU\\Software\\Wine" /v "HideWineExports" /t REG_SZ /d "Y" /f

    # No documented silent install option, unfortunately.
    w_try_cd "$W_CACHE/$W_PACKAGE"
    w_ahk_do <<'EOF'
        SetTitleMatchMode, RegEx
        Title := "i)MetaTrader|Setup"

        ; Maximum time for setup to complete.
        Timeout := 600000 ; 10 min.

        ; Searching for a setup EXE file.
        loop, Files, *.exe
        {
            ExePath := A_LoopFileFullPath
            break
        }

        ; Running setup.
        Run, %ExePath%

        ; Awaiting for setup window to appear.
        loop 120
        {
            if (WinExist(Title))
                break
            if (WinExist("i)Proxy Server"))
            {
                WinActivate, i)Proxy Server
                Send, {Esc}
            }
            Sleep, 1000
            if (A_Index == 120)
                ExitApp, 1
        }

        ; Click Next aggressively.
        loop 10
        {
            WinActivate, %Title%
            WinWaitActive, %Title%,, 2
            if (!ErrorLevel)
            {
                Send, {Enter}
                Send, !n
                Sleep, 3000
                WinGetText, winText, %Title%
                if (InStr(winText, "Next") == 0)
                    break
            }
            Sleep, 1000
        }

        StartTime := A_TickCount

        loop
        {
            ; Check if timeout have passed.
            if (A_TickCount - StartTime > Timeout)
            {
                ExitApp, 1 ; Exit with error on timeout
            }

            ; Close a blocking "Proxy Server" dialog if it appears.
            if (WinExist("i)Proxy Server"))
            {
                WinActivate, i)Proxy Server
                Send, {Esc}
                Sleep, 1000
            }

            ; Check if terminal process is running as a sign of completion.
            Process, Exist, terminal.exe
            if (ErrorLevel)
                break

            ; Check for completion text in the window.
            WinGetText, winText, %Title%
            if (InStr(winText, "Finish") or InStr(winText, "Готово") or InStr(winText, "Ende") or InStr(winText, "Terminar"))
                break

            Sleep, 2000
        }

        ; Clicking "Finish".
        WinActivate, %Title%
        Send, {Enter}
        Send, !f
        Sleep, 5000

        ; Awaiting for terminal process and window to appear.
        loop 60
        {
            Process, Exist, terminal.exe
            if (ErrorLevel)
                break
            Sleep, 1000
        }
        WinWaitActive, i)MetaTrader,, 60

        ; Closing dialogs and exiting from the terminal.
        Send, {Esc}
        Sleep, 1000
        Send, {Esc}
        Sleep, 1000
        Send, !f
        Sleep, 1000
        Send, x
        Sleep, 1000
        Send, !{F4}

        ; Awaiting terminal window to close for 20s.
        loop 20
        {
            Process, Exist, terminal.exe
            if (!ErrorLevel)
                break
            Sleep, 1000
        }

        ; If terminal didn't close in 20s then we are forcing it to close.
        Process, Close, terminal.exe
EOF
}
