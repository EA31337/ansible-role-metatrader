---
extends: default
ignore: |
  .cache
  .git
rules:
  comments:
    min-spaces-from-content: 1
  comments-indentation: false
  braces:
    max-spaces-inside: 1
  line-length:
    max: 120
    level: warning
  new-line-at-end-of-file:
    level: warning
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  trailing-spaces:
    level: warning
  truthy:
    ignore: |-
      .github/workflows/*.yml
